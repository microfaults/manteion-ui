# manteion-ui environment — copy to .env.local and adjust for your setup.
# All VITE_ vars are baked into the client bundle at build time — no secrets.

# manteion-go API. In dev, point at the Vite proxy (http://localhost:5173)
# so /api/v1/* is proxied to localhost:9090. Open the VM1 tunnel in another
# terminal (see docs/ops/connecting-to-vm1.md):
#   ssh -L 9090:localhost:9090 pmundra@2262-cse115b-01.be.ucsc.edu \
#       'kubectl port-forward svc/manteion 9090:8080'
# Set to a direct URL only for non-dev or non-proxy setups.
VITE_MANTEION_URL=http://localhost:5173

# Active kustomize overlay — shown in sidebar, sent as X-Faults-Lab-Environment.
VITE_DEFAULT_ENV=online-boutique

# Grafana dashboard links. Reachable from *your browser*, not via the Vite
# proxy. Open in another terminal:
#   ssh -L 3001:localhost:3001 pmundra@2262-cse115b-01.be.ucsc.edu \
#       'kubectl port-forward svc/grafana 3001:3000'
# Leave blank to hide Grafana links.
#VITE_GRAFANA_URL=http://localhost:3001

# Prometheus HTTP API for the dashboard observability cards (live RPS, p99,
# error rate, cache-hit). Default routes through the Vite proxy at
# /prometheus/api/v1/* → 127.0.0.1:9091 (avoids CORS). Open the tunnel:
#   ssh -L 9091:localhost:9091 pmundra@2262-cse115b-01.be.ucsc.edu \
#       'kubectl port-forward svc/prometheus 9091:9090'
VITE_PROMETHEUS_URL=http://localhost:5173/prometheus
