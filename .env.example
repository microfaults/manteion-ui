# manteion-ui environment — copy to .env.local and adjust for your setup.
# All VITE_ vars are baked into the client bundle at build time — no secrets.

# manteion-go API. In dev, point at the Vite proxy (http://localhost:5173)
# so /api/v1/* is proxied to localhost:9090 (kubectl port-forward
# svc/manteion 9090:9090). Set to a direct URL only for non-dev or non-proxy
# setups.
VITE_MANTEION_URL=http://localhost:5173

# Active kustomize overlay — shown in sidebar, sent as X-Faults-Lab-Environment.
VITE_DEFAULT_ENV=online-boutique

# Grafana dashboard links. Reachable from *your browser*, not via the Vite
# proxy. kubectl port-forward svc/grafana 3001:3000. Leave blank to hide
# Grafana links.
#VITE_GRAFANA_URL=http://localhost:3001

# Prometheus HTTP API for the dashboard observability cards (live RPS, p99,
# error rate, cache-hit). In dev, set to http://localhost:5173/prometheus
# to route through the Vite proxy (avoids CORS). The proxy forwards to
# kubectl port-forward svc/prometheus 9091:9090.
VITE_PROMETHEUS_URL=http://localhost:5173/prometheus
